ODISSEO_ENV=local
ODISSEO_SITE_URL=https://ulissesflores.com
ODISSEO_OUTPUT_FILE=output/odisseo-signal-atlas-report.md
ODISSEO_TARGET_REPOS=500
ODISSEO_X_SEARCH_ENDPOINT=https://api.x.com/2/tweets/search/recent
ODISSEO_X_MAX_RESULTS_PER_PAGE=100
ODISSEO_X_PAGES_PER_QUERY=5
ODISSEO_X_MIN_REQUEST_INTERVAL_SECONDS=0.25
ODISSEO_X_LOOKBACK_DAYS=3
ODISSEO_X_MAX_BACKFILL_DAYS=14
ODISSEO_X_WINDOW_HOURS=12
ODISSEO_X_REFRESH_LIVE_WINDOW=true
ODISSEO_X_RATE_LIMIT_DEFAULT_WAIT_SECONDS=60
ODISSEO_X_RATE_LIMIT_MAX_WAIT_SECONDS=900
ODISSEO_CANDIDATE_TARGET_MULTIPLIER=1.15
ODISSEO_QUERY_HISTORY_FILE=cache/query_history.json
ODISSEO_QUERY_HISTORY_RETENTION_DAYS=30
ODISSEO_X_BEARER_TOKEN=replace_me
ODISSEO_GITHUB_TOKEN=
