ODISSEO_ENV=local
ODISSEO_SITE_URL=https://ulissesflores.com
ODISSEO_OUTPUT_FILE=output/odisseo-signal-atlas.local.md
ODISSEO_TARGET_REPOS=150
ODISSEO_X_SEARCH_ENDPOINT=https://api.x.com/2/tweets/search/recent
ODISSEO_X_MAX_RESULTS_PER_PAGE=20
ODISSEO_X_PAGES_PER_QUERY=2
ODISSEO_X_LOOKBACK_DAYS=2
ODISSEO_X_WINDOW_HOURS=12
ODISSEO_X_REFRESH_LIVE_WINDOW=true
ODISSEO_QUERY_HISTORY_FILE=cache/query_history.json
ODISSEO_QUERY_HISTORY_RETENTION_DAYS=30
ODISSEO_X_BEARER_TOKEN=replace_me
ODISSEO_GITHUB_TOKEN=
